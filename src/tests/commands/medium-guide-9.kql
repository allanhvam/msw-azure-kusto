// make-series + anomaly detection
datatable(BeginTime:datetime, DamageProperty:real)
[
  datetime(2024-01-01), 10.0,
  datetime(2024-01-02), 11.0,
  datetime(2024-01-03), 50.0,
  datetime(2024-01-04), 10.5,
  datetime(2024-01-05), 10.8
]
| make-series AvgDamage = avg(DamageProperty) on BeginTime from datetime(2024-01-01) to datetime(2024-01-06) step 1d
| extend Anomalies = series_decompose_anomalies(AvgDamage)