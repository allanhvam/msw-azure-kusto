{
    "chat.tools.terminal.autoApprove": {
        "/^node --run build$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node --run test$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node --run build && node --run test 2>&1 \\| tail -\\d+$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "npx tsc": true,
        "/^node --run test 2>&1$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node --run test 2>&1 \\| tail -\\d+$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node --run build 2>&1$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^node --run build 2>&1 \\| head -\\d+$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "/^npm run build && node --run test$/": {
            "approve": true,
            "matchCommandLine": true
        }
    }
